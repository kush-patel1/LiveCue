rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fields that only Cloud Functions (admin SDK) may write.
    // Client code can NEVER set these — even on the user's own document.
    function isPlanField(data) {
      return data.keys().hasAny([
        'plan', 'planOverride', 'planExpiry',
        'stripeCustomerId', 'stripeSubscriptionId', 'teamId'
      ]);
    }

    // Returns true if the calling user is a member or owner of a team.
    function isTeamMember(teamId) {
      let team = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return team.ownerId == request.auth.uid || team.memberIds.hasAny([request.auth.uid]);
    }

    // Users can read their own document and write non-plan fields only.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && !isPlanField(request.resource.data.diff(resource.data).affectedKeys());
    }

    // _grants: authenticated users may read their own grant (matched by email).
    // Write is blocked entirely from client code — use Firebase Console only.
    match /_grants/{email} {
      allow read: if request.auth != null
        && request.auth.token.email.lower() == email;
      allow write: if false;
    }

    // Teams: owner can read/write their team doc (members list, invites).
    // Members can read the team doc (to resolve team membership in usePlan).
    // All writes go through Cloud Functions except owner managing invites.
    match /teams/{teamId} {
      allow read: if request.auth != null && isTeamMember(teamId);
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
    }

    // Cues: authenticated user who can read the parent project may read/write its cues.
    // projectRef on the cue doc holds the Firestore project document ID.
    match /cues/{docId} {
      allow read, write: if request.auth != null && (
        resource == null
        || (
          get(/databases/$(database)/documents/projects/$(resource.data.projectRef)).data.owner == request.auth.uid
          || (
            get(/databases/$(database)/documents/projects/$(resource.data.projectRef)).data.teamId != null
            && isTeamMember(get(/databases/$(database)/documents/projects/$(resource.data.projectRef)).data.teamId)
          )
        )
      );
    }

    match /projects/{docId} {
      allow read, write: if request.auth != null && (
        resource == null
        || resource.data.owner == request.auth.uid
        || (resource.data.teamId != null && isTeamMember(resource.data.teamId))
      );
    }
  }
}
