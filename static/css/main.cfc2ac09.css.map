.sp-shell {
  display: flex;
  height: 100vh;
  background: var(--bg-main);
  overflow: hidden;
}

.sp-main {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.sp-topbar {
  padding: 28px 36px 22px;
  border-bottom: 1px solid var(--border-main);
  flex-shrink: 0;
}

.sp-topbar-title {
  color: var(--text-primary);
  font-size: 20px;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
}

.sp-topbar-sub {
  color: var(--text-muted);
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  margin-top: 4px;
}

/* ── Feedback toast ─────────────────────────────────────────────────────────── */
.sp-feedback {
  padding: 11px 36px;
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  flex-shrink: 0;
}
.sp-feedback-ok  { background: rgba(87,132,147,0.15); color: var(--teal); border-bottom: 1px solid var(--teal-dim); }
.sp-feedback-err { background: rgba(147,87,87,0.15);  color: #c87070;     border-bottom: 1px solid rgba(147,87,87,0.2); }

/* ── Content ────────────────────────────────────────────────────────────────── */
.sp-content {
  padding: 28px 36px 48px;
  display: flex;
  flex-direction: column;
  gap: 36px;
  max-width: 660px;
}

/* ── Section ────────────────────────────────────────────────────────────────── */
.sp-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sp-section-label {
  color: var(--text-muted);
  font-size: 11px;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 2px;
}

.sp-section-label-danger { color: #c87070; }

/* ── Card ───────────────────────────────────────────────────────────────────── */
.sp-card {
  background: var(--bg-card);
  border: 1px solid var(--border-main);
  border-radius: 10px;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sp-card-danger {
  border-color: rgba(147,87,87,0.25);
}

.sp-card-title {
  color: var(--text-primary);
  font-size: 14px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
}

.sp-card-desc {
  color: var(--text-muted);
  font-size: 12px;
  font-family: 'Inter', sans-serif;
  margin-top: -4px;
}

/* ── Input ──────────────────────────────────────────────────────────────────── */
.sp-input {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border-input);
  border-radius: 8px;
  color: var(--text-primary);
  font-size: 14px;
  font-family: 'Inter', sans-serif;
  padding: 9px 12px;
  outline: none;
  transition: border-color 0.12s;
  color-scheme: dark;
  box-sizing: border-box;
}

.sp-input:focus { border-color: var(--teal); }

/* ── Inline fields (side by side) ───────────────────────────────────────────── */
.sp-inline-fields {
  display: flex;
  gap: 12px;
}

.sp-inline-fields .sp-input { flex: 1; }

.sp-field-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sp-field-label {
  color: var(--text-muted);
  font-size: 11px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* ── Buttons ────────────────────────────────────────────────────────────────── */
.sp-btn-save {
  align-self: flex-start;
  background: var(--teal);
  color: #fff6ee;
  border: none;
  border-radius: 8px;
  padding: 8px 18px;
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.12s;
}

.sp-btn-save:hover:not(:disabled) { background: var(--teal-hover); }
.sp-btn-save:disabled { opacity: 0.4; cursor: not-allowed; }

.sp-btn-danger {
  background: rgba(147,87,87,0.15);
  color: #c87070;
  border: 1px solid rgba(147,87,87,0.3);
  border-radius: 8px;
  padding: 8px 18px;
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.12s, color 0.12s;
}

.sp-btn-danger:hover:not(:disabled) {
  background: rgba(147,87,87,0.25);
  color: #e08080;
}

.sp-btn-danger:disabled { opacity: 0.35; cursor: not-allowed; }

/* ── Danger row (title + button side by side) ───────────────────────────────── */
.sp-danger-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

/* ── Theme toggle row ───────────────────────────────────────────────────────── */
.sp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: var(--bg-card);
  border: 1px solid var(--border-main);
  border-radius: 10px;
  gap: 20px;
}

.sp-row-info {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.sp-row-title {
  color: var(--text-primary);
  font-size: 14px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
}

.sp-row-desc {
  color: var(--text-muted);
  font-size: 12px;
  font-family: 'Inter', sans-serif;
}

.sp-theme-toggle {
  display: flex;
  background: var(--bg-main);
  border: 1px solid var(--border-main);
  border-radius: 8px;
  padding: 3px;
  gap: 3px;
  flex-shrink: 0;
}

.sp-theme-btn {
  background: none;
  border: none;
  border-radius: 6px;
  padding: 7px 16px;
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}

.sp-theme-btn.active {
  background: var(--teal);
  color: #fff6ee;
}

.sp-theme-btn:not(.active):hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

/* ── Plan section ── */
.sp-card-plan { padding: 20px 22px; }

.sp-plan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  flex-wrap: wrap;
  gap: 12px;
}

.sp-plan-badge-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.sp-plan-badge {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 980px;
}
.sp-plan-badge--free  { background: rgba(255,255,255,0.08); color: var(--text-muted); border: 1px solid rgba(255,255,255,0.12); }
.sp-plan-badge--pro   { background: rgba(87,132,147,0.2);   color: #7ec0d0;           border: 1px solid rgba(87,132,147,0.4); }
.sp-plan-badge--team  { background: rgba(120,90,200,0.2);   color: #b39ddb;           border: 1px solid rgba(120,90,200,0.4); }

.sp-plan-tagline {
  font-size: 12px;
  color: var(--text-muted);
}

.sp-btn-upgrade {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 13px;
  background: linear-gradient(135deg, var(--teal, #578493) 0%, #3d7080 100%);
  color: #fff;
  border: none;
  border-radius: 980px;
  padding: 8px 18px;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
  white-space: nowrap;
}
.sp-btn-upgrade:hover { opacity: 0.88; transform: translateY(-1px); }

/* Usage bars */
.sp-plan-usage { display: flex; flex-direction: column; gap: 14px; }

.sp-usage-row { display: flex; flex-direction: column; gap: 5px; }

.sp-usage-label {
  display: flex;
  justify-content: space-between;
  font-size: 12.5px;
  color: var(--text-secondary, rgba(255,255,255,0.6));
}
.sp-usage-count { color: var(--text-muted); }

.sp-usage-bar {
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 4px;
  overflow: hidden;
}
.sp-usage-fill {
  height: 100%;
  background: var(--teal, #578493);
  border-radius: 4px;
  transition: width 0.4s ease;
  min-width: 0;
}

/* Feature flags */
.sp-plan-features {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 20px;
  margin-top: 4px;
}
.sp-plan-feat {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12.5px;
  color: var(--text-secondary, rgba(255,255,255,0.6));
}
.sp-plan-feat--off { color: var(--text-muted); opacity: 0.5; }
.sp-plan-feat-dot { font-size: 11px; }
.sp-plan-feat:not(.sp-plan-feat--off) .sp-plan-feat-dot { color: #7ec0d0; }

/* ── Team section ───────────────────────────────────────────────────────────── */
.sp-team-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sp-team-seats {
  font-size: 12px;
  font-family: 'Inter', sans-serif;
  color: var(--text-muted);
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border-main);
  border-radius: 980px;
  padding: 2px 10px;
}

.sp-team-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 2px;
}

.sp-team-member {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  background: var(--bg-main);
  border: 1px solid var(--border-main);
  border-radius: 8px;
}

.sp-team-member--pending { opacity: 0.75; }

.sp-team-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: rgba(87,132,147,0.25);
  color: #7ec0d0;
  font-size: 12px;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sp-team-avatar--member  { background: rgba(120,90,200,0.2);  color: #b39ddb; }
.sp-team-avatar--pending { background: rgba(255,255,255,0.06); color: var(--text-muted); }

.sp-team-member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}

.sp-team-member-name {
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sp-team-member-uid {
  font-size: 11px;
  color: var(--text-muted);
  font-family: monospace;
}

.sp-team-member-role {
  font-size: 11px;
  color: var(--text-muted);
  font-family: 'Inter', sans-serif;
}

.sp-team-member-role--pending { color: rgba(180,150,80,0.8); }

.sp-team-remove {
  background: none;
  border: 1px solid rgba(147,87,87,0.3);
  border-radius: 6px;
  color: #c87070;
  font-size: 12px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  padding: 4px 10px;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.12s;
}

.sp-team-remove:hover:not(:disabled) { background: rgba(147,87,87,0.12); }
.sp-team-remove:disabled { opacity: 0.4; cursor: not-allowed; }

.sp-team-invite {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-top: 4px;
}

.sp-team-invite .sp-input { flex: 1; }
.sp-team-invite .sp-btn-save { flex-shrink: 0; }

.sp-team-empty {
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  color: var(--text-muted);
  padding: 10px 0 4px;
}

.sp-team-full {
  font-size: 12px;
  font-family: 'Inter', sans-serif;
  color: var(--text-muted);
  padding: 6px 0;
  font-style: italic;
}
