/* ── Fonts ── */
@font-face {
  font-family: "Inter-Thin";
  src: url("../../Inter/Inter-Thin.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-Light";
  src: url("../../Inter/Inter-Light.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-Regular";
  src: url("../../Inter/Inter-Regular.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-Medium";
  src: url("../../Inter/Inter-Medium.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-SemiBold";
  src: url("../../Inter/Inter-SemiBold.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-Bold";
  src: url("../../Inter/Inter-Bold.ttf") format("truetype");
}
@font-face {
  font-family: "Inter-ExtraBold";
  src: url("../../Inter/Inter-ExtraBold.ttf") format("truetype");
}
@font-face {
  font-family: "Jitter";
  src: url("../../Jitter.otf") format("opentype");
}

/* ── Palette ── */
:root {
  --cream: #fff6ee;
  --white: #ffffff;
  --teal: #578493;
  --teal-dark: #3d6470;
  --terra: #935757;
  --terra-dark: #7a4040;
  --dark: #1b1c1d;
  --near-black: #141414;
  --text-dark: #1b1c1d;
  --text-muted: #6b7280;
  --border: rgba(87, 132, 147, 0.15);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Nav ── */
.lp-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 6%;
  height: 68px;
  background: rgba(255, 246, 238, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.lp-nav-logo {
  height: 32px;
  cursor: pointer;
}

.lp-nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
}

.lp-nav-links a,
.lp-nav-links span {
  font-family: "Inter-Medium";
  font-size: 15px;
  color: var(--text-dark);
  text-decoration: none;
  opacity: 0.75;
  transition: opacity 0.2s;
  cursor: pointer;
}

.lp-nav-links a:hover,
.lp-nav-links span:hover { opacity: 1; }

.lp-nav-cta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.btn-nav-login {
  font-family: "Inter-Medium";
  font-size: 14px;
  color: var(--text-dark);
  background: none;
  border: none;
  cursor: pointer;
  opacity: 0.75;
  transition: opacity 0.2s;
  padding: 0;
}
.btn-nav-login:hover { opacity: 1; }

.btn-nav-signup {
  font-family: "Inter-SemiBold";
  font-size: 14px;
  background: var(--teal);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 9px 20px;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-nav-signup:hover { background: var(--teal-dark); }

/* ── Hero ── */
.lp-hero {
  min-height: 100vh;
  background: var(--cream);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120px 6% 80px;
}

.lp-hero-eyebrow {
  font-family: "Inter-Medium";
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 20px;
}

.lp-hero-title {
  font-family: "Inter-ExtraBold";
  font-size: clamp(42px, 6vw, 80px);
  line-height: 1.08;
  color: var(--text-dark);
  max-width: 820px;
  margin-bottom: 24px;
}

.lp-hero-title span { color: var(--teal); }

.lp-hero-sub {
  font-family: "Inter-Regular";
  font-size: clamp(16px, 2vw, 20px);
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.65;
  margin-bottom: 44px;
}

.lp-hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
}

.btn-primary-lp {
  font-family: "Inter-SemiBold";
  font-size: 16px;
  background: var(--teal);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 14px 32px;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.btn-primary-lp:hover { background: var(--teal-dark); transform: translateY(-1px); }

.btn-secondary-lp {
  font-family: "Inter-SemiBold";
  font-size: 16px;
  background: transparent;
  color: var(--text-dark);
  border: 1.5px solid rgba(27,28,29,0.2);
  border-radius: 10px;
  padding: 14px 32px;
  cursor: pointer;
  transition: border-color 0.2s, transform 0.15s;
}
.btn-secondary-lp:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-1px); }

.lp-hero-scroll-hint {
  margin-top: 60px;
  font-family: "Inter-Light";
  font-size: 13px;
  color: var(--text-muted);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.lp-hero-scroll-hint::after {
  content: "";
  width: 1px;
  height: 40px;
  background: var(--teal);
  opacity: 0.4;
}

/* ── Section shell ── */
.lp-section {
  padding: 100px 6%;
}
.lp-section-white { background: var(--white); }
.lp-section-cream { background: var(--cream); }
.lp-section-dark { background: var(--near-black); color: white; }

.lp-section-label {
  font-family: "Inter-Medium";
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 14px;
}
.lp-section-dark .lp-section-label { color: #7ec0d0; }

.lp-section-heading {
  font-family: "Inter-ExtraBold";
  font-size: clamp(28px, 3.5vw, 48px);
  line-height: 1.15;
  color: var(--text-dark);
  max-width: 640px;
  margin-bottom: 18px;
}
.lp-section-dark .lp-section-heading { color: white; }

.lp-section-body {
  font-family: "Inter-Regular";
  font-size: 17px;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 48px;
}
.lp-section-dark .lp-section-body { color: rgba(255,255,255,0.6); }

/* ── How it works steps ── */
.lp-steps {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 32px;
  max-width: 1100px;
  margin: 0 auto;
}

.lp-step {
  background: var(--white);
  border-radius: 16px;
  padding: 36px 32px;
  border: 1px solid var(--border);
  transition: box-shadow 0.2s, transform 0.2s;
}
.lp-step:hover { box-shadow: 0 12px 40px rgba(87,132,147,0.12); transform: translateY(-3px); }

.lp-step-num {
  font-family: "Inter-ExtraBold";
  font-size: 48px;
  color: var(--teal);
  opacity: 0.18;
  line-height: 1;
  margin-bottom: 12px;
}

.lp-step-title {
  font-family: "Inter-Bold";
  font-size: 18px;
  color: var(--text-dark);
  margin-bottom: 10px;
}

.lp-step-desc {
  font-family: "Inter-Regular";
  font-size: 15px;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ── Use cases ── */
.lp-usecases {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  max-width: 1100px;
  margin: 0 auto;
}

.lp-usecase {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 28px 24px;
  text-align: center;
  transition: background 0.2s, transform 0.2s;
}
.lp-usecase:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); }

.lp-usecase-icon {
  font-size: 32px;
  margin-bottom: 12px;
}

.lp-usecase-name {
  font-family: "Inter-SemiBold";
  font-size: 15px;
  color: white;
}

/* ── Features grid ── */
.lp-features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 28px;
  max-width: 1100px;
  margin: 0 auto;
}

.lp-feature {
  padding: 32px 28px;
  border-radius: 16px;
  background: var(--cream);
  border: 1px solid var(--border);
  transition: box-shadow 0.2s, transform 0.2s;
}
.lp-feature:hover { box-shadow: 0 8px 32px rgba(87,132,147,0.1); transform: translateY(-2px); }

.lp-feature-icon {
  font-size: 28px;
  margin-bottom: 16px;
}

.lp-feature-title {
  font-family: "Inter-Bold";
  font-size: 17px;
  color: var(--text-dark);
  margin-bottom: 10px;
}

.lp-feature-desc {
  font-family: "Inter-Regular";
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.65;
}

/* ── Pricing teaser ── */
.lp-pricing-teaser {
  text-align: center;
  max-width: 640px;
  margin: 0 auto;
}

.lp-pricing-cards {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 48px;
}

.lp-price-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 36px 32px;
  min-width: 240px;
  max-width: 280px;
  flex: 1;
  text-align: left;
  transition: box-shadow 0.2s, transform 0.2s;
  position: relative;
}
.lp-price-card:hover { box-shadow: 0 12px 40px rgba(87,132,147,0.12); transform: translateY(-3px); }

.lp-price-card.featured {
  border-color: var(--teal);
  box-shadow: 0 0 0 1px var(--teal), 0 12px 40px rgba(87,132,147,0.15);
}

.lp-price-badge {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--teal);
  color: white;
  font-family: "Inter-SemiBold";
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 20px;
}

.lp-price-plan {
  font-family: "Inter-SemiBold";
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 8px;
}

.lp-price-amount {
  font-family: "Inter-ExtraBold";
  font-size: 40px;
  color: var(--text-dark);
  line-height: 1;
  margin-bottom: 4px;
}
.lp-price-amount sup {
  font-size: 20px;
  vertical-align: super;
  font-family: "Inter-Bold";
}
.lp-price-period {
  font-family: "Inter-Regular";
  font-size: 14px;
  color: var(--text-muted);
  margin-bottom: 20px;
}

.lp-price-divider {
  height: 1px;
  background: var(--border);
  margin: 20px 0;
}

.lp-price-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}
.lp-price-features li {
  font-family: "Inter-Regular";
  font-size: 14px;
  color: var(--text-muted);
  display: flex;
  gap: 8px;
  align-items: flex-start;
}
.lp-price-features li::before {
  content: "✓";
  color: var(--teal);
  font-weight: 700;
  flex-shrink: 0;
}

.btn-price {
  width: 100%;
  padding: 12px;
  border-radius: 9px;
  font-family: "Inter-SemiBold";
  font-size: 15px;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  border: none;
}
.btn-price:hover { transform: translateY(-1px); }

.btn-price-primary { background: var(--teal); color: white; }
.btn-price-primary:hover { background: var(--teal-dark); }
.btn-price-outline { background: transparent; color: var(--teal); border: 1.5px solid var(--teal) !important; }
.btn-price-outline:hover { background: var(--teal); color: white; }
.btn-price-terra { background: var(--terra); color: white; }
.btn-price-terra:hover { background: var(--terra-dark); }

/* ── CTA Banner ── */
.lp-cta-banner {
  background: var(--teal);
  padding: 80px 6%;
  text-align: center;
}

.lp-cta-banner h2 {
  font-family: "Inter-ExtraBold";
  font-size: clamp(28px, 3.5vw, 48px);
  color: white;
  margin-bottom: 16px;
}

.lp-cta-banner p {
  font-family: "Inter-Regular";
  font-size: 18px;
  color: rgba(255,255,255,0.8);
  margin-bottom: 36px;
}

.btn-cta-white {
  font-family: "Inter-SemiBold";
  font-size: 16px;
  background: white;
  color: var(--teal);
  border: none;
  border-radius: 10px;
  padding: 14px 32px;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  margin: 6px;
}
.btn-cta-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

.btn-cta-outline-white {
  font-family: "Inter-SemiBold";
  font-size: 16px;
  background: transparent;
  color: white;
  border: 1.5px solid rgba(255,255,255,0.6);
  border-radius: 10px;
  padding: 14px 32px;
  cursor: pointer;
  transition: border-color 0.2s, transform 0.15s;
  margin: 6px;
}
.btn-cta-outline-white:hover { border-color: white; transform: translateY(-2px); }

/* ── Footer ── */
.lp-footer {
  background: var(--near-black);
  padding: 60px 6% 32px;
  color: rgba(255,255,255,0.5);
}

.lp-footer-top {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 40px;
  margin-bottom: 48px;
}

.lp-footer-brand img {
  height: 28px;
  margin-bottom: 14px;
  filter: brightness(0) invert(1);
  opacity: 0.8;
}

.lp-footer-brand p {
  font-family: "Inter-Regular";
  font-size: 14px;
  max-width: 240px;
  line-height: 1.6;
}

.lp-footer-col h4 {
  font-family: "Inter-SemiBold";
  font-size: 13px;
  color: white;
  margin-bottom: 16px;
  letter-spacing: 0.04em;
}

.lp-footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lp-footer-col ul a {
  font-family: "Inter-Regular";
  font-size: 14px;
  color: rgba(255,255,255,0.45);
  text-decoration: none;
  transition: color 0.2s;
}
.lp-footer-col ul a:hover { color: rgba(255,255,255,0.85); }

.lp-footer-divider {
  height: 1px;
  background: rgba(255,255,255,0.07);
  margin-bottom: 24px;
}

.lp-footer-bottom {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  font-family: "Inter-Regular";
  font-size: 13px;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .lp-nav-links { display: none; }
  .lp-hero { padding: 100px 5% 60px; }
  .lp-steps, .lp-usecases, .lp-features { grid-template-columns: 1fr; }
  .lp-pricing-cards { flex-direction: column; align-items: center; }
  .lp-price-card { max-width: 100%; min-width: unset; width: 100%; }
  .lp-footer-top { flex-direction: column; }
}
