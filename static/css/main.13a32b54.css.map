/* ─────────────────────────────────────────────
   ADMIN PAGE — Control Room
   Deep dark, monospace readouts, glowing status
───────────────────────────────────────────── */

:root {
  --cr-bg:        #090b0d;
  --cr-surface:   #0d1014;
  --cr-panel:     #101418;
  --cr-card:      #12161a;
  --cr-border:    #1c2228;
  --cr-border-hi: #263038;
  --cr-teal:      #578493;
  --cr-teal-glow: rgba(87,132,147,0.25);
  --cr-teal-dim:  rgba(87,132,147,0.12);
  --cr-text:      #c8d4da;
  --cr-text-dim:  #4a5a64;
  --cr-text-faint:#2a3840;
  --cr-green:     #39d353;
  --cr-red:       #f85149;
  --cr-amber:     #d29922;
  --cr-live-glow: rgba(87,132,147,0.35);
}

/* ── Shell ── */
.adm-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--cr-bg);
  color: var(--cr-text);
  font-family: 'Inter', sans-serif;
}

/* ── Top bar ── */
.adm-topbar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  height: 44px;
  background: var(--cr-surface);
  border-bottom: 1px solid var(--cr-border);
}

.adm-topbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}

.adm-brand {
  font-family: 'Jitter', sans-serif;
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  letter-spacing: 0.02em;
}
.adm-brand-live { color: var(--cr-teal); }
.adm-brand-cue  { color: var(--cr-text); }

.adm-topbar-sep {
  color: var(--cr-text-faint);
  font-size: 14px;
}

.adm-topbar-project {
  font-size: 13px;
  font-weight: 600;
  color: var(--cr-text);
}

.adm-topbar-date {
  font-size: 11px;
  color: var(--cr-text-dim);
}

.adm-topbar-center {
  flex-shrink: 0;
}

.adm-on-air {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-red);
  padding: 4px 12px;
  border: 1px solid rgba(248,81,73,0.35);
  border-radius: 4px;
  background: rgba(248,81,73,0.07);
}

.adm-on-air-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--cr-red);
  box-shadow: 0 0 8px var(--cr-red);
  animation: adm-blink 1.1s ease-in-out infinite;
}

@keyframes adm-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.2; }
}

.adm-standby {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-text-dim);
  padding: 4px 12px;
  border: 1px solid var(--cr-border);
  border-radius: 4px;
}

.adm-topbar-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
}

.adm-topbar-clock {
  font-size: 14px;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  font-family: 'Inter', sans-serif;
  color: var(--cr-text);
  letter-spacing: 0.04em;
}

/* Drift badge (top bar) */
.adm-drift-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 3px 9px;
  border-radius: 3px;
}
.adm-drift--ok    { color: var(--cr-green);  background: rgba(57,211,83,0.1);  border: 1px solid rgba(57,211,83,0.2); }
.adm-drift--late  { color: var(--cr-red);    background: rgba(248,81,73,0.1);  border: 1px solid rgba(248,81,73,0.2); }
.adm-drift--early { color: var(--cr-amber);  background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.2); }

/* ── Body ── */
.adm-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ── Console sidebar ── */
.adm-console {
  flex-shrink: 0;
  width: 240px;
  display: flex;
  flex-direction: column;
  background: var(--cr-surface);
  border-right: 1px solid var(--cr-border);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--cr-border) transparent;
}

/* Module = one console "rack unit" */
.adm-module {
  border-bottom: 1px solid var(--cr-border);
}

.adm-module-label {
  padding: 6px 14px 5px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--cr-text-dim);
  background: var(--cr-panel);
  border-bottom: 1px solid var(--cr-border);
  text-transform: uppercase;
}

.adm-module-body {
  padding: 12px 14px;
}

/* SHOW TIMER module */
.adm-big-timer {
  font-size: 30px;
  font-weight: 700;
  font-family: 'Inter', sans-serif;
  letter-spacing: 0.06em;
  color: var(--cr-text-dim);
  font-variant-numeric: tabular-nums;
  transition: color 0.3s;
}

.adm-big-timer--running {
  color: var(--cr-teal);
  text-shadow: 0 0 16px var(--cr-teal-glow);
}

.adm-cue-progress-label {
  font-size: 10px;
  color: var(--cr-text-dim);
  margin-top: 5px;
  margin-bottom: 8px;
  line-height: 1.4;
}

.adm-progress-track {
  height: 3px;
  background: var(--cr-border);
  border-radius: 2px;
  overflow: hidden;
}

.adm-progress-fill {
  height: 100%;
  background: var(--cr-teal);
  border-radius: 2px;
  transition: width 1s linear;
}

/* TRANSPORT module */
.adm-go-live-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 11px 0;
  background: transparent;
  border: 1px solid var(--cr-red);
  border-radius: 5px;
  color: var(--cr-red);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.12em;
  cursor: pointer;
  transition: background 0.15s, box-shadow 0.15s;
}

.adm-go-live-btn:hover {
  background: rgba(248,81,73,0.1);
  box-shadow: 0 0 12px rgba(248,81,73,0.2);
}

.adm-go-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--cr-red);
  box-shadow: 0 0 6px var(--cr-red);
}

.adm-transport-row {
  display: flex;
  gap: 6px;
}

.adm-transport-btn {
  flex: 1;
  padding: 9px 0;
  background: var(--cr-panel);
  border: 1px solid var(--cr-border-hi);
  border-radius: 5px;
  color: var(--cr-text-dim);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}

.adm-transport-btn:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

.adm-transport-btn--play {
  background: var(--cr-teal);
  border-color: var(--cr-teal);
  color: #fff;
  font-size: 16px;
  box-shadow: 0 0 10px var(--cr-teal-glow);
}

.adm-transport-btn--pause {
  background: rgba(87,132,147,0.2);
  border-color: var(--cr-teal);
  color: var(--cr-teal);
  box-shadow: none;
}

/* CUE CONTROL module */
.adm-cue-nav-row {
  display: flex;
  gap: 6px;
  margin-bottom: 10px;
}

.adm-cue-nav-btn {
  flex: 1;
  padding: 9px 0;
  background: var(--cr-panel);
  border: 1px solid var(--cr-border-hi);
  border-radius: 5px;
  color: var(--cr-text-dim);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  cursor: pointer;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}

.adm-cue-nav-btn:hover:not(:disabled) {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

.adm-cue-nav-btn--next {
  border-color: rgba(87,132,147,0.4);
  color: var(--cr-teal);
}

.adm-cue-nav-btn--next:hover:not(:disabled) {
  background: var(--cr-teal-dim);
}

.adm-cue-nav-btn:disabled {
  opacity: 0.25;
  cursor: not-allowed;
}

/* Live readout */
.adm-live-readout {
  background: var(--cr-panel);
  border: 1px solid var(--cr-border);
  border-radius: 5px;
  padding: 8px 10px;
  margin-bottom: 10px;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.adm-readout-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.adm-readout-key {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-text-faint);
  min-width: 46px;
  margin-top: 1px;
}

.adm-readout-val {
  font-size: 11px;
  color: var(--cr-text);
  line-height: 1.4;
  word-break: break-word;
}

/* Next cue block */
.adm-next-cue-block {
  background: var(--cr-teal-dim);
  border: 1px solid rgba(87,132,147,0.2);
  border-radius: 5px;
  padding: 9px 10px;
}

.adm-next-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-teal);
  margin-bottom: 4px;
}

.adm-next-title {
  font-size: 11px;
  font-weight: 600;
  color: var(--cr-text);
  margin-bottom: 4px;
  line-height: 1.4;
}

.adm-next-countdown {
  font-size: 13px;
  font-weight: 700;
  font-family: 'Inter', sans-serif;
  color: var(--cr-teal);
  letter-spacing: 0.04em;
}

.adm-next-countdown--urgent {
  color: var(--cr-amber);
  animation: adm-blink 0.8s ease-in-out infinite;
}

/* BROADCAST module */
.adm-broadcast-input {
  width: 100%;
  background: var(--cr-panel);
  border: 1px solid var(--cr-border-hi);
  border-radius: 5px;
  color: var(--cr-text);
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  line-height: 1.5;
  padding: 8px 10px;
  resize: none;
  box-sizing: border-box;
  margin-bottom: 8px;
  transition: border-color 0.15s;
}

.adm-broadcast-input::placeholder { color: var(--cr-text-dim); }
.adm-broadcast-input:focus {
  outline: none;
  border-color: rgba(210, 153, 34, 0.5);
}

.adm-broadcast-actions {
  display: flex;
  gap: 6px;
  margin-bottom: 6px;
}

.adm-broadcast-send {
  flex: 1;
  padding: 8px 0;
  background: rgba(210, 153, 34, 0.12);
  border: 1px solid rgba(210, 153, 34, 0.4);
  border-radius: 5px;
  color: #e8c76a;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: background 0.12s, box-shadow 0.12s;
}

.adm-broadcast-send:hover:not(:disabled) {
  background: rgba(210, 153, 34, 0.2);
  box-shadow: 0 0 10px rgba(210, 153, 34, 0.15);
}

.adm-broadcast-send:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.adm-broadcast-clear {
  padding: 8px 12px;
  background: transparent;
  border: 1px solid var(--cr-border-hi);
  border-radius: 5px;
  color: var(--cr-text-dim);
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}

.adm-broadcast-clear:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

.adm-broadcast-hint {
  font-size: 10px;
  color: var(--cr-text-dim);
  margin: 0;
  line-height: 1.4;
}

/* SHARE module */
.adm-module--share .adm-module-body {
  padding: 10px 14px 12px;
}

.adm-url-display {
  font-size: 9px;
  font-family: 'Inter', sans-serif;
  color: var(--cr-text-dim);
  background: var(--cr-panel);
  border: 1px solid var(--cr-border);
  border-radius: 4px;
  padding: 7px 8px;
  word-break: break-all;
  line-height: 1.5;
  margin-bottom: 8px;
}

.adm-copy-btn {
  width: 100%;
  padding: 7px 0;
  background: transparent;
  border: 1px solid var(--cr-border-hi);
  border-radius: 4px;
  color: var(--cr-text-dim);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}

.adm-copy-btn:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

/* ── Runway (right side) ── */
.adm-runway-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--cr-bg);
}

.adm-runway-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 7px 20px;
  border-bottom: 1px solid var(--cr-border);
  background: var(--cr-surface);
}

.adm-runway-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--cr-text-dim);
}

.adm-runway-count {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--cr-text-faint);
}

.adm-runway {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 16px 20px 20px;
  scrollbar-width: thin;
  scrollbar-color: var(--cr-border) transparent;
}

.adm-runway::-webkit-scrollbar { height: 5px; }
.adm-runway::-webkit-scrollbar-thumb {
  background: var(--cr-border-hi);
  border-radius: 3px;
}

/* ── Cue cards ── */
.adm-card {
  flex-shrink: 0;
  width: 310px;
  border-radius: 8px;
  background: var(--cr-card);
  border: 1px solid var(--cr-border);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: opacity 0.2s;
  position: relative;
}

.adm-card--past   { opacity: 0.32; }
.adm-card--live   {
  width: 340px;
  border-color: var(--cr-teal);
  box-shadow: 0 0 0 1px var(--cr-teal), 0 0 24px var(--cr-live-glow);
  opacity: 1;
}
.adm-card--next   { opacity: 1; border-color: var(--cr-border-hi); }
.adm-card--future { opacity: 0.55; }

/* Status strip at top of each card */
.adm-card-strip {
  height: 3px;
  width: 100%;
}

.adm-card-strip--past   { background: var(--cr-text-faint); }
.adm-card-strip--live   { background: var(--cr-teal); box-shadow: 0 0 8px var(--cr-teal); }
.adm-card-strip--next   { background: var(--cr-border-hi); }
.adm-card-strip--future { background: var(--cr-border); }

/* Card inner */
.adm-card-head {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px 16px 0;
}

.adm-num {
  flex-shrink: 0;
  font-size: 12px;
  font-weight: 800;
  width: 26px;
  height: 26px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.02em;
}

.adm-num--past   { background: var(--cr-border); color: var(--cr-text-dim); }
.adm-num--live   { background: var(--cr-teal); color: #fff; box-shadow: 0 0 8px var(--cr-teal-glow); }
.adm-num--next   { background: var(--cr-border-hi); color: var(--cr-text); }
.adm-num--future { background: var(--cr-border); color: var(--cr-text-dim); }

.adm-card-title-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.adm-card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--cr-text);
  line-height: 1.3;
}

.adm-live-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-teal);
}

.adm-next-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--cr-text-dim);
}

/* Drift pill on card */
.adm-drift-pill {
  flex-shrink: 0;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 3px;
  letter-spacing: 0.06em;
  margin-top: 2px;
}

/* Times row */
.adm-card-times {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 9px 16px 0;
  flex-wrap: wrap;
}

.adm-mono {
  font-family: 'Inter', sans-serif;
  font-variant-numeric: tabular-nums;
}

.adm-time-val {
  font-size: 13px;
  font-weight: 500;
  color: var(--cr-text-dim);
}

.adm-time-sep {
  font-size: 12px;
  color: var(--cr-text-faint);
}

.adm-dur {
  margin-left: 3px;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 3px;
  background: var(--cr-teal-dim);
  color: var(--cr-teal);
  letter-spacing: 0.04em;
}

/* Live progress on card */
.adm-card-progress {
  height: 2px;
  background: var(--cr-border);
  margin: 8px 16px 0;
  border-radius: 1px;
  overflow: hidden;
}

.adm-card-progress-fill {
  height: 100%;
  background: var(--cr-teal);
  transition: width 1s linear;
}

.adm-actual-start {
  font-size: 11px;
  color: var(--cr-text-dim);
  font-style: italic;
  padding: 6px 16px 0;
  font-family: 'Inter', sans-serif;
}

/* Fields */
.adm-card-fields {
  margin: 10px 0 0;
  padding: 10px 16px 16px;
  display: flex;
  flex-direction: column;
  gap: 7px;
  border-top: 1px solid var(--cr-border);
}

.adm-field-row {
  display: flex;
  gap: 8px;
  align-items: flex-start;
  line-height: 1.4;
}

.adm-f-key {
  flex-shrink: 0;
  width: 90px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--cr-text-dim);
  text-transform: uppercase;
  margin-top: 1px;
}

.adm-f-val {
  flex: 1;
  font-size: 13px;
  color: var(--cr-text);
  word-break: break-word;
}

.adm-f-empty {
  color: var(--cr-text-faint);
}

/* Edit button on each card */
.adm-card-edit-btn {
  flex-shrink: 0;
  background: transparent;
  border: none;
  color: var(--cr-text-dim);
  font-size: 13px;
  cursor: pointer;
  padding: 2px 4px;
  border-radius: 4px;
  line-height: 1;
  opacity: 0;
  transition: opacity 0.15s, background 0.12s, color 0.12s;
}

.adm-card:hover .adm-card-edit-btn {
  opacity: 1;
}

.adm-card-edit-btn:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

/* ── Cue editor drawer ── */
.adm-drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 100;
}

.adm-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 380px;
  background: var(--cr-surface);
  border-left: 1px solid var(--cr-border-hi);
  z-index: 101;
  display: flex;
  flex-direction: column;
  animation: adm-slide-in 0.2s ease-out;
}

@keyframes adm-slide-in {
  from { transform: translateX(100%); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

.adm-drawer-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--cr-border);
  background: var(--cr-panel);
}

.adm-drawer-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--cr-text-dim);
  display: block;
  margin-bottom: 4px;
}

.adm-drawer-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--cr-text);
  margin: 0;
  line-height: 1.3;
}

.adm-drawer-close {
  background: transparent;
  border: none;
  color: var(--cr-text-dim);
  font-size: 16px;
  cursor: pointer;
  padding: 4px 6px;
  border-radius: 4px;
  line-height: 1;
  margin-top: -2px;
  transition: background 0.12s, color 0.12s;
}

.adm-drawer-close:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

.adm-drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  scrollbar-width: thin;
  scrollbar-color: var(--cr-border) transparent;
}

.adm-editor-section-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--cr-text-dim);
  text-transform: uppercase;
  padding-top: 4px;
  border-top: 1px solid var(--cr-border);
}

.adm-editor-row {
  display: flex;
  gap: 12px;
}

.adm-editor-row .adm-editor-field {
  flex: 1;
}

.adm-editor-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.adm-editor-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--cr-text-dim);
  text-transform: uppercase;
}

.adm-editor-input {
  background: var(--cr-panel);
  border: 1px solid var(--cr-border-hi);
  border-radius: 6px;
  color: var(--cr-text);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  padding: 8px 10px;
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.15s;
}

.adm-editor-input::placeholder { color: var(--cr-text-dim); }

.adm-editor-input:focus {
  outline: none;
  border-color: var(--cr-teal);
}

/* time input color fix */
.adm-editor-input[type="time"]::-webkit-calendar-picker-indicator {
  filter: invert(0.5);
  cursor: pointer;
}

.adm-drawer-footer {
  display: flex;
  gap: 10px;
  padding: 16px 20px;
  border-top: 1px solid var(--cr-border);
  background: var(--cr-panel);
}

.adm-drawer-cancel {
  flex: 1;
  padding: 10px 0;
  background: transparent;
  border: 1px solid var(--cr-border-hi);
  border-radius: 6px;
  color: var(--cr-text-dim);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}

.adm-drawer-cancel:hover {
  background: var(--cr-border-hi);
  color: var(--cr-text);
}

.adm-drawer-save {
  flex: 2;
  padding: 10px 0;
  background: var(--cr-teal);
  border: none;
  border-radius: 6px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.15s;
}

.adm-drawer-save:hover {
  opacity: 0.88;
}

/* Empty runway */
.adm-empty {
  color: var(--cr-text-faint);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  padding: 60px 0;
  margin: auto;
}

